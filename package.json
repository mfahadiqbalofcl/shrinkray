{
  "name": "shrinkray",
  "version": "1.3.0",
  "description": "Local-first image compressor. Target a file size in KB, or target visual quality and let it find the smallest file. AVIF, WebP, JPEG, PNG, JXL. ZIP in/out, parallel, handles 1GB+ archives.",
  "type": "module",
  "license": "MIT",
  "author": "Fahad Iqbal (@mfahadiqbalofcl)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfahadiqbalofcl/shrinkray.git"
  },
  "homepage": "https://github.com/mfahadiqbalofcl/shrinkray#readme",
  "bugs": {
    "url": "https://github.com/mfahadiqbalofcl/shrinkray/issues"
  },
  "bin": {
    "shrinkray": "./bin/shrinkray.js"
  },
  "main": "./src/pipeline.js",
  "exports": {
    ".": "./src/pipeline.js",
    "./metric": "./src/metric.js",
    "./formats": "./src/formats.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "cli": "node bin/shrinkray.js",
    "calibrate": "node tools/calibrate.js",
    "test": "node --test 'test/*.test.js'"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "image",
    "compression",
    "avif",
    "webp",
    "jpeg",
    "jxl",
    "optimize",
    "squoosh",
    "target-size",
    "dssim",
    "local-first"
  ],
  "files": [
    "bin",
    "src",
    "public",
    "tools",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "fflate": "^0.8.3",
    "sharp": "^0.35.3",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  }
}
